// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String      @id @default(cuid())
  username  String      @unique
  password  String
  name      String?
  role      UserRole    @default(ADMIN)
  isActive  Boolean     @default(true)
  
  quotations Quotation[]
  invoices   Invoice[]
  logs       ActivityLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  OWNER
  ADMIN
}

model DocumentSequence {
  type      String // "QUOTATION" atau "INVOICE"
  year      Int
  lastUrut  Int    @default(0)
  
  @@id([type, year])
}

model Quotation {
  id                    String   @id @default(uuid())
  nomorSurat            String   @unique
  nomorUrut             Int
  tanggal               String
  namaKlien             String?
  companyName           String?
  clientName            String?
  up                    String?
  lokasi                String?
  
  namaPenandatangan     String
  jabatanPenandatangan  String
  phonePenandatangan    String?
  ttdStempelUrl         String?
  logoUrl               String?

  showLingkupKerja      Boolean  @default(true)
  showSyaratGaransi     Boolean  @default(true)
  isHargaSatuanMode     Boolean  @default(false)
  isJasaBahanMode       Boolean  @default(false)
  isMaterialOnlyMode    Boolean  @default(false)
  kenakanPPN            Boolean  @default(false)
  diskon                Float    @default(0)
  totalHarga            Float    @default(0)
  isInvoiced            Boolean  @default(false)

  termin                String   
  lingkupKerja          String   
  syaratGaransi         String   

  items                 QuotationItem[]
  
  // Tracking
  createdById           String?
  createdBy             User?    @relation(fields: [createdById], references: [id])

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  
  deskripsi   String
  bahan       String?
  volume      Float     @default(0)
  satuan      String    @default("m²")
  harga       Float     @default(0)
  hargaBahan  Float     @default(0)
  hargaJasa   Float     @default(0)
  
  orderIndex  Int       @default(0)
}

model MasterItem {
  id          String   @id @default(uuid())
  deskripsi   String   @unique
  bahan       String?
  satuan      String   @default("m²")
  harga       Float    @default(0)
  hargaBahan  Float    @default(0)
  hargaJasa   Float    @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalSetting {
  id          String   @id
  value       String   
  updatedAt   DateTime @updatedAt
}

model Signatory {
  id          String   @id @default(uuid())
  nama        String   @unique
  jabatan     String
  phone       String?
  ttdUrl      String?  
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id                String        @id @default(uuid())
  invoiceNumber     String        @unique
  nomorUrut         Int           @default(0)
  date              DateTime      @default(now())
  dueDate           DateTime?
  clientName        String?
  companyName       String?
  clientAddress     String?
  items             InvoiceItem[]
  subtotal          Decimal       @default(0)
  quotationId       String?       
  taxRate           Decimal       @default(0.11)
  taxApplied        Boolean       @default(false)
  taxAmount         Decimal       @default(0)
  discountAmount    Decimal       @default(0)   
  downPayment       Decimal       @default(0)   
  notes             String?       
  paymentMethod     String        @default("CASH")
  total             Decimal       @default(0)
  invoiceType       String        @default("PELUNASAN")
  status            InvoiceStatus @default(PENDING)
  
  namaPenandatangan     String?
  jabatanPenandatangan  String?
  phonePenandatangan    String?
  ttdStempelUrl         String? 
  
  // Tracking
  createdById           String?
  createdBy             User?    @relation(fields: [createdById], references: [id])

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}

model InvoiceItem {
  id           String   @id @default(uuid())
  description  String
  quantity     Int
  volume       Decimal?
  satuan       String?
  unitPrice    Decimal
  lineTotal    Decimal   @default(0)
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId    String
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

model Client {
  id           String   @id @default(uuid())
  companyName  String?  
  clientName   String?  
  address      String?
  phone        String?
  email        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([companyName, clientName])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  target    String?
  details   String?
  createdAt DateTime @default(now())
}
